# Copiez ce fichier en .env et renseignez vos valeurs Supabase.
# Project Settings > API dans votre dashboard Supabase.
# La clé anon est publique : elle peut figurer dans le front-end.
# Ne commitez JAMAIS la clé service_role.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Mot de passe superadmin — saisi dans l'UI superadmin (B1.2), jamais stocké ici.
# Valeur indicative uniquement (la vraie valeur est définie manuellement dans app_config).
VITE_ECCLESIA_SUPERADMIN_PASSWORD_HINT="(saisi par l'utilisateur via UI dans B1.2)"
